# Hugging Face access token (free) — create one at https://huggingface.co/settings/tokens
# A "Read" token is sufficient. Required for "Cloud" mode (and optional for a
# private "Custom" endpoint). Not needed at all for "On-device" mode.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "Cloud" mode model. Must be a model that is actually served by an HF inference
# provider. The Chonlasitk Burmese fine-tune is NOT hosted on any provider, so
# use it through "Custom endpoint" mode instead. Default is a multilingual model
# that handles Burmese out of the box.
HF_MODEL=openai/whisper-large-v3

# Optional default for "Custom endpoint" mode. Point at your own HF Space /
# Inference Endpoint running Chonlasitk/whisper-burmese. Users can also type a
# URL directly in the UI, which overrides this.
# HF_ENDPOINT_URL=https://your-endpoint.example/transcribe
