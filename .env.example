# Hugging Face access token (free) — create one at https://huggingface.co/settings/tokens
# A "Read" token is sufficient. Required for the transcription API route.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model repo used for transcription. Defaults to the Burmese Whisper Large V3 fine-tune.
# You can override this with any HF automatic-speech-recognition model.
HF_MODEL=Chonlasitk/whisper-burmese
